-- JUMP POWER + LOW GRAVITY
-- ============================================================
local gravAttach = nil
local gravForce  = nil
local jumpConn   = nil

local function clearOldGrav()
    pcall(function()
        local c = LP.Character
        if not c then return end
        local hrp = c:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        for _, d in ipairs(hrp:GetChildren()) do
            if (d:IsA("VectorForce") or d:IsA("BodyForce") or d:IsA("Attachment"))
               and d.Name:find("BHB") then
                d:Destroy()
            end
        end
    end)
end

local function startJumpGrav()
    clearOldGrav()
    local c = LP.Character
    if not c then return end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    local hum = c:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    hum.JumpPower = S.jumpPower

    gravAttach = Instance.new("Attachment")
    gravAttach.Name   = "BHB_GravAttach"
    gravAttach.Parent = hrp

    gravForce = Instance.new("VectorForce")
    gravForce.Name                = "BHB_GravForce"
    gravForce.Attachment0         = gravAttach
    gravForce.ApplyAtCenterOfMass = true
    gravForce.RelativeTo          = Enum.ActuatorRelativeTo.World
    gravForce.Parent              = hrp

    jumpConn = RunService.Heartbeat:Connect(function()
        if not S.jumpGravOn then return end
        pcall(function()
            local c2 = LP.Character
            if not c2 then return end
            local hum2 = c2:FindFirstChildOfClass("Humanoid")
            if hum2 then hum2.JumpPower = S.jumpPower end
            local mass = 0
            for _, p in ipairs(c2:GetDescendants()) do if p:IsA("BasePart") then mass+=p:GetMass() end end
            gravForce.Force = Vector3.new(0, mass * 196.2 * 0.52, 0)
        end)
    end)
end
local function stopJumpGrav()
    if jumpConn then jumpConn:Disconnect(); jumpConn = nil end
    clearOldGrav(); gravAttach=nil; gravForce=nil
    local c = LP.Character
    if c then
        local hum = c:FindFirstChildOfClass("Humanoid")
        if hum then hum.JumpPower = 50 end
    end
end

