local function mkFloatBtn(label,posY,color,cb)
    local btn=Instance.new("TextButton",sg)
    btn.Size=UDim2.new(0,60,0,60)
    btn.Position=UDim2.new(1,-72,0,posY)
    btn.BackgroundColor3=color btn.BorderSizePixel=0
    btn.Text="" btn.AutoButtonColor=false corner(btn,99)
    local bs=stroke(btn,C.cyan,2.2)
    task.spawn(function()
        local hue=0 while btn and btn.Parent do
            hue=(hue+0.01)%1 bs.Color=Color3.fromHSV(hue,0.9,1) task.wait(0.05)
        end
    end)
    local ll=Instance.new("TextLabel",btn)
    ll.Size=UDim2.new(1,0,1,0) ll.BackgroundTransparency=1
    ll.Text=label ll.TextColor3=Color3.fromRGB(255,255,255)
    ll.Font=Enum.Font.GothamBold ll.TextSize=10 ll.TextWrapped=true
    ll.TextXAlignment=Enum.TextXAlignment.Center
    -- Drag
    local fd,fs,fp,fdist
    btn.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            fd=true; fs=i.Position; fp=btn.Position; fdist=0
            i.Changed:Connect(function()
                if i.UserInputState==Enum.UserInputState.End then
                    fd=false
                    if fdist<8 then cb(btn,ll) end
                end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if fd and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
            local d=i.Position-fs fdist=d.Magnitude
            btn.Position=UDim2.new(fp.X.Scale,fp.X.Offset+d.X,fp.Y.Scale,fp.Y.Offset+d.Y)
        end
    end)
    -- pulse
    local c2=Color3.fromRGB(math.clamp(color.R*255-35,0,255),math.clamp(color.G*255-35,0,255),math.clamp(color.B*255-35,0,255))
    task.spawn(function()
        while btn and btn.Parent do
            TweenService:Create(btn,TweenInfo.new(1,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{BackgroundColor3=c2}):Play()
            task.wait(1)
            TweenService:Create(btn,TweenInfo.new(1,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{BackgroundColor3=color}):Play()
            task.wait(1)
        end
    end)
    return btn,ll
end

