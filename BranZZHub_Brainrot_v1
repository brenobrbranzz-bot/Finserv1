-- SECURE PLATFORM  ← REESCRITA TOTAL
-- ============================================================
local platPart    = nil   -- a Part no workspace
local platConn    = nil   -- RunService connection
local platPaused  = false -- pausado?
local platTargetY = nil   -- Y alvo atual (nil = parado)
local platSpeedDir= 0     -- +1 subindo, -1 descendo, 0 parado

local function destroyPlatform()
    -- Para tudo
    if platConn then platConn:Disconnect(); platConn = nil end
    platPaused  = false
    platTargetY = nil
    platSpeedDir= 0
    -- Remove parts no workspace
    pcall(function()
        for _, o in ipairs(workspace:GetChildren()) do
            if o.Name == "BHB_Platform" then o:Destroy() end
        end
    end)
    if platPart then pcall(function() platPart:Destroy() end); platPart = nil end
end

local function buildPlatform()
    destroyPlatform()
    -- Começa ABAIXO do mapa
    local startY = -3000
    local p = Instance.new("Part")
    p.Name        = "BHB_Platform"
    p.Anchored    = true
    p.CanCollide  = true
    p.CanTouch    = true
    p.Size        = Vector3.new(8192, 8, 8192)   -- COBRE TUDO
    p.Material    = Enum.Material.Neon
    p.Color       = Color3.fromRGB(30, 0, 80)
    p.Transparency= 0.4
    p.CFrame      = CFrame.new(0, startY, 0)
    p.Parent      = workspace
    platPart      = p
    -- Borda RGB
    pcall(function()
        local sel = Instance.new("SelectionBox", p)
        sel.Adornee             = p
        sel.LineThickness        = 0.1
        sel.SurfaceTransparency = 1
        task.spawn(function()
            local hue = 0
            while sel and sel.Parent do
                hue = (hue+0.008)%1
                sel.Color3 = Color3.fromHSV(hue,1,1)
                task.wait(0.05)
            end
        end)
    end)
    return p
end

local function startPlatformLoop()
    if platConn then platConn:Disconnect(); platConn = nil end
    platConn = RunService.Heartbeat:Connect(function(dt)
        if not S.platformOn then return end
        if not platPart or not platPart.Parent then return end
        if platPaused then return end
        if platSpeedDir == 0 then return end  -- parado: não move

        local curY   = platPart.CFrame.Position.Y
        local spd    = S.platSpeed * 60 * dt * platSpeedDir
        local newY   = curY + spd

        platPart.CFrame = CFrame.new(0, newY, 0)

        -- Leva o player junto se estiver em cima
        local c2 = LP.Character
        if c2 then
            local hrp2 = c2:FindFirstChild("HumanoidRootPart")
            if hrp2 then
                local platTop = newY + 4   -- topo da plat (altura/2)
                local py      = hrp2.Position.Y
                -- player está "em cima" se está dentro de ~5 studs do topo
                if py >= platTop - 3 and py <= platTop + 6 then
                    hrp2.CFrame = CFrame.new(
                        hrp2.Position.X,
                        platTop + 4,
                        hrp2.Position.Z
                    )
                end
            end
        end
    end)
end

