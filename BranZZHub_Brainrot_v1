-- Linha neon entre dois pontos
local function makeLine(from, to, color)
    if not from or not to then return end
    local dist = (to - from).Magnitude
    if dist < 1 then return end
    local mid = (from + to) / 2
    local p = Instance.new("Part")
    p.Name        = "BHB_Line"
    p.Size        = Vector3.new(0.12, 0.12, dist)
    p.CFrame      = CFrame.lookAt(mid, to)
    p.Anchored    = true
    p.CanCollide  = false
    p.CanTouch    = false
    p.Material    = Enum.Material.Neon
    p.Color       = color
    p.Transparency= 0.15
    p.Parent      = workspace
    table.insert(espLines, p)
end

local function runESP()
    local data = scanLocalServer()
    local sig  = ""
    for i, d in ipairs(data) do
        sig = sig..(d.key or "").."|"
        if i >= 10 then break end
    end

    -- Notificações
    for _, item in ipairs(data) do
        if not notifiedKeys[item.key] then
            notifiedKeys[item.key] = true
            if item.danger then
                notify("⚠️ PERIGO!", item.name.." — "..item.ownerName, 7)
            elseif item.rarity == "BigBang" or item.rarity == "Diamond" then
                notify("🔥 Lendário!", item.name.." ["..item.rarity.."] — "..item.ownerName, 6)
            end
        end
    end

    if sig == lastESPSig then return data end
    lastESPSig = sig
    clearESP()

    local c   = LP.Character
    local hrp = c and c:FindFirstChild("HumanoidRootPart")
    local from = hrp and hrp.Position or nil

    for i, item in ipairs(data) do
        makeESP(item, i)
        if from then
            -- Linha até o brainrot
            if item.pos and item.pos ~= Vector3.new(0,0,0) then
                local lineColor = item.danger and C.red or C.yellow
                -- Lendários: laranja/rosa
                if not item.danger then
                    if item.rarity == "BigBang" then lineColor = C.bigbang
                    elseif item.rarity == "Diamond" then lineColor = C.diamond
                    elseif item.rarity == "Gold" then lineColor = C.gold end
                end
                makeLine(from, item.pos, lineColor)
            end
            -- Linha branca até a base
            if item.basePos and item.basePos ~= Vector3.new(0,0,0) then
                makeLine(from, item.basePos, Color3.fromRGB(255,255,255))
            end
        end
    end
    return data
end

