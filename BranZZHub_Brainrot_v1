-- Brainrots perigosos: linha VERMELHA
local DANGER = {
    ["urubini flamenguini"] = true,
    ["não chorax"]          = true,
}

local function isBrazilrotName(text)
    local tl = text:lower()
    for _, name in ipairs(BRAZILROT_LIST) do
        if tl:find(name:lower(), 1, true) then return name end
    end
    return nil
end

local function getBrainrotRarity(brainrotName)
    local RS = ReplicatedStorage
    for _, rarityName in ipairs(RARITY_ORDER) do
        local folder
        local BBase = RS:FindFirstChild("Brainrots")
        if BBase then folder = BBase:FindFirstChild(rarityName) end
        if not folder then folder = RS:FindFirstChild(rarityName) end
        if folder then
            for _, model in ipairs(folder:GetChildren()) do
                if model.Name:lower():find(brainrotName:lower(), 1, true) or
                   brainrotName:lower():find(model.Name:lower(), 1, true) then
                    return rarityName
                end
            end
        end
    end
    local BV = workspace:FindFirstChild("BrainrotsVisual")
    if BV then
        for _, rarityName in ipairs(RARITY_ORDER) do
            local folder = BV:FindFirstChild(rarityName)
            if folder then
                for _, obj in ipairs(folder:GetDescendants()) do
                    if obj:IsA("TextLabel") then
                        local t = (obj.Text or obj.ContentText or ""):lower()
                        if t:find(brainrotName:lower(), 1, true) then return rarityName end
                    end
                end
            end
        end
    end
    return "Normal"
end

-- ============================================================
-- PARSE GEN (do Finder v2)
-- ============================================================
local function parseGen(text)
    local b = text:match("([%d%.]+)%s*[Bb]")
    if b then return tonumber(b)*1000000 end
    local m = text:match("([%d%.]+)%s*[Mm]")
    if m then return tonumber(m)*1000 end
    local k = text:match("([%d%.]+)%s*[Kk]")
    if k then return tonumber(k) end
    local n = text:match("([%d%.]+)%s*/s")
    if n then return tonumber(n)/1000 end
    return 0
end

-- ============================================================
-- SCAN BASES (do Finder v2, com basePos)
-- ============================================================
local function scanLocalServer()
    local results = {}
    local seen    = {}
    local bases   = workspace:FindFirstChild("Bases")
    if not bases then return results end

    for _, base in ipairs(bases:GetChildren()) do
        local ownerName = "?"
        local ownerId   = 0

        -- Detecta dono pela Placa
        local placa = base:FindFirstChild("Placa", true)
        if placa then
            for _, desc in ipairs(placa:GetDescendants()) do
                if desc:IsA("TextLabel") then
                    local t = (desc.Text or ""):match("^%s*(.-)%s*$")
                    if t and t ~= "" then
                        for _, p in ipairs(Players:GetPlayers()) do
                            if p.Name:lower() == t:lower() or
                               (p.DisplayName or ""):lower() == t:lower() then
                                ownerName = p.DisplayName ~= "" and p.DisplayName or p.Name
                                ownerId   = p.UserId
                                break
                            end
                        end
                        if ownerId == 0 then ownerName = t end
                    end
                end
            end
        end
        -- Tenta pegar pelo Owner
        if ownerName == "?" then
            local ow = base:FindFirstChild("Owner")
            if ow and ow:IsA("StringValue") then ownerName = ow.Value end
        end

        -- Posição da base (para linha branca)
        local basePart = base:FindFirstChildOfClass("BasePart")
        if not basePart then
            for _, d in ipairs(base:GetDescendants()) do
                if d:IsA("BasePart") and d.Name ~= "HumanoidRootPart" then
                    basePart = d; break
                end
            end
        end
        local basePos = basePart and basePart.Position or nil

        -- Slots
        local sf = base:FindFirstChild("Slots")
        if not sf then
            for _, d in ipairs(base:GetDescendants()) do
                if d.Name == "Slots" then sf = d; break end
            end
        end
        if not sf then continue end

        for i = 1, 100 do
            local sObj = sf:FindFirstChild("s"..i)
            if not sObj then continue end
            for _, desc in ipairs(sObj:GetDescendants()) do
                if desc.Name == "BrainrotBillboard" then
                    pcall(function()
                        local labels = {}
                        for _, o in ipairs(desc:GetDescendants()) do
                            if o:IsA("TextLabel") then
                                local t = (o.Text or o.ContentText or ""):match("^%s*(.-)%s*$")
                                if t and t ~= "" and t ~= " " then
                                    local dup = false
                                    for _, ex in ipairs(labels) do if ex==t then dup=true break end end
                                    if not dup then table.insert(labels, t) end
                                end
                            end
                        end
                        if #labels == 0 then return end
                        local key = table.concat(labels, "|")
                        if seen[key] then return end
                        seen[key] = true

                        local foundName, genText, genVal = nil, "", 0
                        for _, lbl in ipairs(labels) do
                            if not foundName then
                                local n = isBrazilrotName(lbl)
                                if n then foundName = n end
                            end
                            if lbl:match("[%d%.]+%s*[BbMmKk]") or lbl:match("[%d%.]+%s*/s") then
                                local v = parseGen(lbl)
                                if v > genVal then genVal = v; genText = lbl:match("^%s*(.-)%s*$") end
                            end
                        end
                        if not foundName then return end

                        local pos = Vector3.new(0,0,0)
                        if desc.Parent and desc.Parent:IsA("BasePart") then
                            pos = desc.Parent.Position
                        elseif sObj:FindFirstChildOfClass("BasePart") then
                            pos = sObj:FindFirstChildOfClass("BasePart").Position
                        end

                        local isDanger = DANGER[foundName:lower()] == true
                        local rarity   = getBrainrotRarity(foundName)

                        table.insert(results, {
                            name      = foundName,
                            genText   = genText,
                            genVal    = genVal,
                            pos       = pos,
                            basePos   = basePos,
                            ownerName = ownerName,
                            ownerId   = ownerId,
                            key       = key,
                            rarity    = rarity,
                            danger    = isDanger,
                        })
                    end)
                end
            end
        end
    end
    table.sort(results, function(a,b) return a.genVal > b.genVal end)
    return results
end

