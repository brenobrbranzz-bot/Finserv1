-- Teclas bloqueadas (não usar): 1-0, W,A,S,D, Espaço
local BLOCKED = {
    [Enum.KeyCode.One]=true,[Enum.KeyCode.Two]=true,[Enum.KeyCode.Three]=true,
    [Enum.KeyCode.Four]=true,[Enum.KeyCode.Five]=true,[Enum.KeyCode.Six]=true,
    [Enum.KeyCode.Seven]=true,[Enum.KeyCode.Eight]=true,[Enum.KeyCode.Nine]=true,
    [Enum.KeyCode.Zero]=true,
    [Enum.KeyCode.W]=true,[Enum.KeyCode.A]=true,[Enum.KeyCode.S]=true,
    [Enum.KeyCode.D]=true,[Enum.KeyCode.Space]=true,
}

UserInputService.InputBegan:Connect(function(inp,gpe)
    if gpe then return end
    if BLOCKED[inp.KeyCode] then return end

    -- P = toggle plataforma
    if inp.KeyCode == Enum.KeyCode.P then
        local newState = not S.platformOn
        if VisualSetters.platformOn then VisualSetters.platformOn(newState,true) end
        S.platformOn = newState
        if newState then
            buildPlatform()
            startPlatformLoop()
            notify("Platform","[P] Plataforma ON",3)
        else
            destroyPlatform()
            notify("Platform","[P] Plataforma OFF",3)
        end

    -- M = mark position
    elseif inp.KeyCode == Enum.KeyCode.M then
        markPosition()

    -- Delete = fecha UI
    elseif inp.KeyCode == Enum.KeyCode.Delete then
        saveState(); destroyPlatform(); clearESP(); sg:Destroy()
    end
end)

