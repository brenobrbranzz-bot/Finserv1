local tpFlashConn   = nil
local byteKillerDone= false
local lastPos_flash = nil

local function killByteGuard()
    if byteKillerDone then return end
    byteKillerDone = true
    pcall(function()
        local ps = LP:FindFirstChild("PlayerScripts")
        if not ps then return end
        for _, name in ipairs({"ByteGuardClient","ClientRec","DiscoEvent"}) do
            local obj = ps:FindFirstChild(name)
            if obj then obj:Destroy() end
        end
        for _, child in ipairs(ps:GetChildren()) do
            local low = child.Name:lower()
            if low:find("guard") or low:find("byte") or low:find("anticheat") then
                child:Destroy()
            end
        end
    end)
end

local function findCaixote()
    local bases = workspace:FindFirstChild("Bases")
    if not bases then return nil end
    local c = LP.Character
    if not c then return nil end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local bestDist, bestPart = math.huge, nil
    for _, base in ipairs(bases:GetChildren()) do
        -- Procura ProximityPrompt em toda a base (dentro de Decorações ou não)
        for _, obj in ipairs(base:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                local pp = obj.Parent
                if pp and pp:IsA("BasePart") then
                    local dist = (pp.Position - hrp.Position).Magnitude
                    if dist < bestDist then bestDist = dist; bestPart = pp end
                end
            end
        end
    end
    return bestPart
end

local function startTpFlash()
    if tpFlashConn then return end
    killByteGuard()
    tpFlashConn = RunService.Heartbeat:Connect(function()
        if not S.tpFlashOn then return end
        local c = LP.Character
        if not c then return end
        local hrp = c:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        -- Detecta TP forçada pelo ByteGuard (delta > 20 studs num frame)
        if lastPos_flash then
            local delta = (hrp.Position - lastPos_flash).Magnitude
            if delta > 20 then
                local caixote = findCaixote()
                if caixote then
                    hrp.CFrame = CFrame.new(caixote.Position + Vector3.new(0,3,0))
                    notify("TP Flash","ByteGuard interceptado! Tpando...",2)
                end
            end
        end
        -- Mini TPs contínuas pro caixote
        local caixote = findCaixote()
        if caixote then
            local dist = (hrp.Position - caixote.Position).Magnitude
            if dist > 4 then
                hrp.CFrame = CFrame.new(hrp.Position:Lerp(caixote.Position + Vector3.new(0,2,0), 0.35))
            end
        end
        lastPos_flash = hrp.Position
    end)
end
local function stopTpFlash()
    if tpFlashConn then tpFlashConn:Disconnect(); tpFlashConn = nil end
    lastPos_flash = nil
end

-- ============================================================
-- TP TWEEN (zigzag até posição marcada)
-- ============================================================
local tweenRunning = false
local tweenConn    = nil

local function startTpTween(targetPos)
    if not targetPos then notify("TP Tween","Marque uma posição primeiro!",3); return end
    if tweenRunning then return end
    local c = LP.Character
    if not c then return end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    local hum = c:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    tweenRunning = true
    hum.PlatformStand = true
    local t = 0
    tweenConn = RunService.Heartbeat:Connect(function(dt)
        if not tweenRunning then return end
        local c2  = LP.Character
        if not c2 then tweenRunning = false return end
        local h2  = c2:FindFirstChild("HumanoidRootPart")
        local hm2 = c2:FindFirstChildOfClass("Humanoid")
        if not h2 or not hm2 then tweenRunning = false return end
        t = t + dt
        local horiz = Vector3.new(targetPos.X - h2.Position.X, 0, targetPos.Z - h2.Position.Z)
        if horiz.Magnitude < 2.5 then
            h2.CFrame = CFrame.new(targetPos)
            hm2.PlatformStand = false
            tweenRunning = false
            tweenConn:Disconnect(); tweenConn = nil
            notify("TP Tween","Chegou!",2)
            return
        end
        local vertOffset = math.sin(t * math.pi / 4) * 6
        local dir = horiz.Unit
        local spd = S.tweenSpeed
        local np = h2.Position + dir * spd * dt
        np = Vector3.new(np.X, h2.Position.Y + vertOffset * dt * 2.5, np.Z)
        h2.CFrame = CFrame.new(np)
    end)
end
local function stopTpTween()
    tweenRunning = false
    if tweenConn then tweenConn:Disconnect(); tweenConn = nil end
    local c = LP.Character
    if c then
        local hum = c:FindFirstChildOfClass("Humanoid")
        if hum then hum.PlatformStand = false end
    end
end

